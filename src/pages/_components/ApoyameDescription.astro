---
export interface Props {
  title: string;  
  description: string;
  url?: string;
}

const { title, description, url } = Astro.props;
---

<div class="mb-8">
  <div class="border-b-2 w-110 mb-4">
    {url ? (
      <a
        href={url}
        class="inline-block text-xl font-bold mb-2 font-deco hover:scale-110"
      >
        <h3 class="text-xl font-bold mb-2 font-deco">
          {title}
        </h3>
      </a>
    ) : (
      <h3 class="text-xl font-bold mb-2 font-deco">
        {title}
      </h3>
    )}
  </div>

  <p class="text-gray-700">{description}</p>
</div>