---
import NavMenu from "./NavMenu.astro";
import menuData from "./menuData.json";
import ButtonTheme from "@shared/components/ButtonTheme.astro";
import Logo from "../../layout/Logo.astro";
---

<header class="header flex items-center justify-between px-4 pb-4 border-b-2 m-5 font-bold">
  <a href="/" class="header-logo text-2xl"><Logo class="text-2xl transition-transform duration-300 hover:scale-110" /></a>
  <div class="header-container flex gap-5 items-center">
    <NavMenu menuData={menuData}/>
    <ButtonTheme colorClass="bg-accent_two" dataIndex="0" />
    <ButtonTheme colorClass="bg-accent_one" dataIndex="1" />
  </div>
</header>