---
import NavMenu from "./NavMenu.astro";
import menuData from "../../pages/_data/menuData.json";
import ButtonTheme from "@shared/components/ButtonTheme.astro";
import Logo from "../../layout/Logo.astro";
---

<header class="header flex items-center justify-between px-4 2xl:px-8 pb-4 2xl:pb-7 border-b-2 m-5 2xl:m-8 font-bold">
  <a href="/" class="header-logo "><Logo class="text-xl xl:text-2xl 2xl:text-3xl transition-transform duration-300 hover:scale-110" /></a>
  <div class="2xl:text-2xl header-container flex gap-5 items-center">
    <NavMenu menuData={menuData}/>
    <ButtonTheme colorClass="bg-accent_two" dataIndex="0" />
    <ButtonTheme colorClass="bg-accent_one" dataIndex="1" />
  </div>
</header>